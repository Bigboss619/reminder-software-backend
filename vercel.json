{
  "version": 2,
  "builds": [
    { "src": "src/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "src/index.js" }
  ],
  "crons": [
    {
      "path": "/api/send-reminders/cron/reminders",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/send-reminders/cron/expiry-reminder",
      "schedule": "0 7 * * *"
    }
  ]
}
