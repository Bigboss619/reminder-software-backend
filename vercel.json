{
  "crons": [
    {
      "path": "/api/send-reminders/cron/reminders",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/send-reminders/cron/expiry-reminder",
      "schedule": "0 7 * * *"
    }
  ],
  "functions": {
    "src/index.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://reminder-software.vercel.app"
        }
      ]
    }
  ]
}
